<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1B3A6B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0F1F3D;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#grad)" />
  
  <!-- Accent elements -->
  <rect x="0" y="0" width="8" height="630" fill="#E8720C" />
  <circle cx="1050" cy="100" r="150" fill="#E8720C" opacity="0.1" />
  <circle cx="150" cy="500" r="100" fill="#E8720C" opacity="0.1" />
  
  <!-- Logo text -->
  <text x="100" y="280" fill="white" font-family="Arial, sans-serif" font-weight="bold" font-size="72" letter-spacing="4">
    CONSTRU<tspan fill="#E8720C">VIAL</tspan>
  </text>
  
  <!-- Tagline -->
  <text x="100" y="350" fill="#F5F7FA" font-family="Arial, sans-serif" font-size="32">
    35 años construyendo infraestructura para Argentina
  </text>
  
  <!-- Stats -->
  <text x="100" y="440" fill="#E8720C" font-family="Arial, sans-serif" font-weight="bold" font-size="24">
    500+ obras finalizadas
  </text>
  <text x="100" y="480" fill="#6B7280" font-family="Arial, sans-serif" font-size="18">
    construvialsa.com.ar
  </text>
</svg>
